BEDS24_REFRESH_TOKEN=
BEDS24_PROPERTY_ID=340623
BEDS24_MARKUP_PERCENT=20
# UZS/USD: 0 = auto (official CBU rate, cached 6h); set a number to override manually
BEDS24_USD_RATE=0
BEDS24_SYNC_DAYS=365
